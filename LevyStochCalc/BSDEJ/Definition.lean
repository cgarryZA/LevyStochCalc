/-- **Regression test #1 (Filt pin)**: The filtration witnessed by an
`IsBSDEJSolution` is EXACTLY the right-continuous augmentation of the
join of `W`'s component natural filtrations with `N`'s natural filtration.

This is the M11-CRIT fix and the P12 F1 closure: previously, the predicate
allowed any filtration containing the natural one, which is satisfied
vacuously by `Filt = ‚ä§` ‚ÄĒ defeating the adaptedness rule-out of the
`Y = W_T ‚ąí W_t` counterexample. Pinning to the canonical augmentation
forces the literature-correct filtration. -/
theorem filtration_eq_canonical
    (h : IsBSDEJSolution W N bsdej X Y Z U T) :
    ‚ąÉ Filt : MeasureTheory.Filtration ‚ĄĚ ‚ÄĻMeasurableSpace ő©‚Äļ,
      Filt = ((‚®Ü i : Fin d,
                  LevyStochCalc.Brownian.Martingale.naturalFiltration (W.W i))
                  ‚äĒ LevyStochCalc.Poisson.naturalFiltration N).rightCont := by
  obtain ‚ü®_, _, _, _, _, Filt, hFilt_eq, _‚ü© := h
  exact ‚ü®Filt, hFilt_eq‚ü©

/-- **Regression test #2 (c√†dl√†g Y)**: The `Y` component of every solution
has a.s.-c√†dl√†g paths (right-continuous with left limits at every point).
This is the Tang-Li / Pardoux-RńÉŇücanu `S¬≤` solution-space requirement,
without which the L¬≤-supremum `‚®Ü t ‚ąą [0,T] ‚ÄĖY t‚ÄĖ¬≤` is not honestly
measurable as a function of ŌČ. -/
theorem Y_cadlag
    (h : IsBSDEJSolution W N bsdej X Y Z U T) :
    ‚ąÄŠĶź ŌČ ‚ąāP, ‚ąÄ t : ‚ĄĚ,
      Filter.Tendsto (fun s => Y s ŌČ) (nhdsWithin t (Set.Ioi t)) (nhds (Y t ŌČ))
        ‚ąß ‚ąÉ L : ‚ĄĚ,
            Filter.Tendsto (fun s => Y s ŌČ) (nhdsWithin t (Set.Iio t)) (nhds L) := by
  obtain ‚ü®_, _, _, _, h_cadlag, _‚ü© := h
  exact h_cadlag

/-- **Regression test #3 (Y adapted to canonical Filt)**: The `Y`
component is `Filt`-adapted where `Filt` is the canonical filtration. -/
theorem Y_adapted_canonical
    (h : IsBSDEJSolution W N bsdej X Y Z U T) :
    ‚ąÉ Filt : MeasureTheory.Filtration ‚ĄĚ ‚ÄĻMeasurableSpace ő©‚Äļ,
      Filt = ((‚®Ü i : Fin d,
                  LevyStochCalc.Brownian.Martingale.naturalFiltration (W.W i))
                  ‚äĒ LevyStochCalc.Poisson.naturalFiltration N).rightCont ‚ąß
      MeasureTheory.Adapted Filt Y := by
  obtain ‚ü®_, _, _, _, _, Filt, hFilt_eq, hY_adapted, _‚ü© := h
  exact ‚ü®Filt, hFilt_eq, hY_adapted‚ü©

/-- **Regression test #4 (Z strongly progressive)**: The `Z` component is
`IsStronglyProgressive` w.r.t. the canonical filtration (strictly stronger
than per-`t` adaptedness, per the P4 F1 fix). This is the
Tang-Li / Pardoux-RńÉŇücanu H¬≤ solution-space requirement: H¬≤ is the L¬≤
space of progressively measurable processes. -/
theorem Z_isStronglyProgressive_canonical
    (h : IsBSDEJSolution W N bsdej X Y Z U T) :
    ‚ąÉ Filt : MeasureTheory.Filtration ‚ĄĚ ‚ÄĻMeasurableSpace ő©‚Äļ,
      Filt = ((‚®Ü i : Fin d,
                  LevyStochCalc.Brownian.Martingale.naturalFiltration (W.W i))
                  ‚äĒ LevyStochCalc.Poisson.naturalFiltration N).rightCont ‚ąß
      MeasureTheory.IsStronglyProgressive Filt Z := by
  obtain ‚ü®_, _, _, _, _, Filt, hFilt_eq, _, hZ_prog, _‚ü© := h
  exact ‚ü®Filt, hFilt_eq, hZ_prog‚ü©

/-- **Regression test #5 (U strongly progressive per mark)**: For every
mark `e : E`, the per-mark slice `s ‚Ü¶ U s ¬∑ e` is `IsStronglyProgressive`
w.r.t. the canonical filtration (H¬≤_N solution-space requirement). -/
theorem U_isStronglyProgressive_canonical
    (h : IsBSDEJSolution W N bsdej X Y Z U T) :
    ‚ąÉ Filt : MeasureTheory.Filtration ‚ĄĚ ‚ÄĻMeasurableSpace ő©‚Äļ,
      Filt = ((‚®Ü i : Fin d,
                  LevyStochCalc.Brownian.Martingale.naturalFiltration (W.W i))
                  ‚äĒ LevyStochCalc.Poisson.naturalFiltration N).rightCont ‚ąß
      ‚ąÄ e : E, MeasureTheory.IsStronglyProgressive Filt (fun s ŌČ => U s ŌČ e) := by
  obtain ‚ü®_, _, _, _, _, Filt, hFilt_eq, _, _, hU_prog, _‚ü© := h
  exact ‚ü®Filt, hFilt_eq, hU_prog‚ü©

/-- **Regression test #6 (M_W pinned to canonical Brownian It√ī integral)**:
The Brownian martingale leg `M_W` of every solution agrees a.s. (at every
T') with the canonical multidim Brownian It√ī integral
`MultidimBrownianMotion.stochasticIntegral W Z ...` ‚ÄĒ not merely with some
L¬≤-isometric stand-in. The per-component Z hypotheses are bundled as
existential witnesses to make the canonical-integral expression well-typed.
This is the H2 fix: previously M_W was only L¬≤-isometric to Z, which left a
non-trivial gap between the predicate and the literature claim. -/
theorem M_W_eq_canonical_brownianIto
    (h : IsBSDEJSolution W N bsdej X Y Z U T) :
    ‚ąÉ M_W : ‚ĄĚ ‚Üí ő© ‚Üí ‚ĄĚ,
      ‚ąÉ (h_Z_meas : ‚ąÄ i : Fin d,
            Measurable (Function.uncurry (fun ŌČ s => Z s ŌČ i)))
         (h_Z_progMeas : ‚ąÄ i : Fin d, ‚ąÄ t : ‚ĄĚ,
            @MeasureTheory.StronglyMeasurable (ő© √ó ‚ĄĚ) ‚ĄĚ _
              (@Prod.instMeasurableSpace ő© ‚ĄĚ
                ((LevyStochCalc.Brownian.Martingale.naturalFiltration (W.W i)).seq t)
                inferInstance)
              (fun p : ő© √ó ‚ĄĚ => Z p.2 p.1 i))
         (h_Z_sq : ‚ąÄ i : Fin d, ‚ąÄ T' : ‚ĄĚ, 0 < T' ‚Üí
            ‚ąę‚ĀĽ ŌČ, ‚ąę‚ĀĽ s in Set.Icc (0 : ‚ĄĚ) T',
              (‚ÄĖZ s ŌČ i‚ÄĖ‚āä : ‚ĄĚ‚Č•0‚ąě) ^ 2 ‚ąāvolume ‚ąāP < ‚ä§),
        ‚ąÄ T' : ‚ĄĚ, ‚ąÄŠĶź ŌČ ‚ąāP,
          M_W T' ŌČ =
            LevyStochCalc.Brownian.Multidim.MultidimBrownianMotion.stochasticIntegral
              W Z h_Z_meas h_Z_progMeas h_Z_sq T' ŌČ := by
  obtain ‚ü®_, _, _, _, _, _Filt, _, _, _, _,
          M_W, _, _, _, _, _,
          ‚ü®h_Z_meas, h_Z_progMeas, h_Z_sq, hM_W_pin‚ü©, _, _, _, _‚ü© := h
  exact ‚ü®M_W, h_Z_meas, h_Z_progMeas, h_Z_sq, hM_W_pin‚ü©

/-- **Regression test #7 (M_N pinned to canonical compensated-Poisson
integral)**: The Poisson martingale leg `M_N` of every solution agrees a.s.
(at every T') with the canonical compensated-Poisson L¬≤ integral
`Compensated.stochasticIntegral N U ...` ‚ÄĒ not merely with some
L¬≤-isometric stand-in. The U-side hypotheses are bundled as existential
witnesses to make the canonical-integral expression well-typed. This is the
H6 closure: previously the M_N pin was hollow because per-e adaptedness of
U was insufficient to type-check the canonical compensator. -/
theorem M_N_eq_canonical_compensatedPoisson
    (h : IsBSDEJSolution W N bsdej X Y Z U T) :
    ‚ąÉ M_N : ‚ĄĚ ‚Üí ő© ‚Üí ‚ĄĚ,
      ‚ąÉ (h_U_meas : Measurable
            (fun (p : ő© √ó ‚ĄĚ √ó E) =>
              (fun ŌČ' s e => U s ŌČ' e) p.1 p.2.1 p.2.2))
         (h_U_progMeas : ‚ąÄ t : ‚ĄĚ,
            @MeasureTheory.StronglyMeasurable (ő© √ó ‚ĄĚ √ó E) ‚ĄĚ _
              (@Prod.instMeasurableSpace ő© (‚ĄĚ √ó E)
                ((LevyStochCalc.Poisson.naturalFiltration N).seq t)
                inferInstance)
              (fun p : ő© √ó ‚ĄĚ √ó E => (fun ŌČ' s e => U s ŌČ' e) p.1 p.2.1 p.2.2))
         (h_U_sq : ‚ąÄ T' : ‚ĄĚ, 0 < T' ‚Üí
            ‚ąę‚ĀĽ ŌČ, ‚ąę‚ĀĽ s in Set.Icc (0 : ‚ĄĚ) T', ‚ąę‚ĀĽ e,
              (‚ÄĖ(fun ŌČ' s e => U s ŌČ' e) ŌČ s e‚ÄĖ‚āä : ‚ĄĚ‚Č•0‚ąě) ^ 2
                ‚ąāőĹ ‚ąāvolume ‚ąāP < ‚ä§),
        ‚ąÄ T' : ‚ĄĚ, ‚ąÄŠĶź ŌČ ‚ąāP,
          M_N T' ŌČ =
            LevyStochCalc.Poisson.Compensated.stochasticIntegral N
              (fun ŌČ' s e => U s ŌČ' e) h_U_meas h_U_progMeas h_U_sq T' ŌČ := by
  obtain ‚ü®_, _, _, _, _, _Filt, _, _, _, _,
          _, M_N, _, _, _, _,
          _, ‚ü®h_U_meas, h_U_progMeas, h_U_sq, hM_N_pin‚ü©, _, _, _‚ü© := h
  exact ‚ü®M_N, h_U_meas, h_U_progMeas, h_U_sq, hM_N_pin‚ü©

