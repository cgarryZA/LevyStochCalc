import LevyStochCalc.Poisson.RandomMeasure

/-!
# Natural filtration of a Poisson random measure

For a `PoissonRandomMeasure N` on `[0, ÔêŞ) ├ù E` over `(╬®, P)`, the *natural
filtration* at time `t` is the ¤â-algebra generated by

  `{ N(B) : B Ôèå (-ÔêŞ, t] ├ù E, B measurable }`,

i.e., by the family of measure-evaluations on past time-rectangles. Mirrors
`LevyStochCalc.Brownian.Martingale.naturalFiltration` for Brownian motion.
The ¤â-algebra is exactly the one already appearing in
`PoissonRandomMeasure.joint_past_future_independent`; this file packages it
as a `MeasureTheory.Filtration ÔäØ mÔéÇ` so that `Martingale` claims can be
stated against it.
-/

namespace LevyStochCalc.Poisson

open MeasureTheory
open scoped NNReal ENNReal

universe u v
variable {╬® : Type u} [MeasurableSpace ╬®]
variable {E : Type v} [MeasurableSpace E]

/-- The *natural filtration* of a Poisson random measure `N`. At time `t`
the ¤â-algebra is `Ô¿å B Ôèå Iic t ├ù univ, ¤â(N(┬À, B))`. -/
noncomputable def naturalFiltration
    {P : Measure ╬®} [IsProbabilityMeasure P]
    {╬¢ : Measure E} [SigmaFinite ╬¢]
    (N : PoissonRandomMeasure P ╬¢) :
    MeasureTheory.Filtration ÔäØ ÔÇ╣MeasurableSpace ╬®ÔÇ║ where
  seq t := Ô¿å B Ôêê { C : Set (ÔäØ ├ù E) | C Ôèå Set.Iic t ├ù╦ó Set.univ Ôêğ MeasurableSet C },
    MeasurableSpace.comap (fun ¤ë => N.N ¤ë B) inferInstance
  mono' s t hst := by
    refine iSup_le fun B => iSup_le fun hB => ?_
    have hB_t :
        B Ôêê { C : Set (ÔäØ ├ù E) | C Ôèå Set.Iic t ├ù╦ó Set.univ Ôêğ MeasurableSet C } := by
      refine Ôş¿?_, hB.2Ôş®
      refine hB.1.trans ?_
      exact Set.prod_mono (Set.Iic_subset_Iic.mpr hst) (le_refl _)
    exact le_iSup_of_le B (le_iSup_of_le hB_t le_rfl)
  le' t := by
    refine iSup_le fun B => iSup_le fun hB => ?_
    intro u hu
    obtain Ôş¿v, hv, hvuÔş® := hu
    rw [ÔåÉ hvu]
    exact (N.measurable_eval hB.2) hv

/-- **Past-meas: each `N(┬À, B)` is `(naturalFiltration N)`-measurable at any
time `t` whose `Iic t ├ù E` contains `B`.** Direct consequence of the
construction of `naturalFiltration`: the ¤â-algebra at time `t` is the
supremum (over past rectangles) of the comap ¤â-algebras. -/
lemma measurable_random_measure_of_le
    {P : Measure ╬®} [IsProbabilityMeasure P]
    {╬¢ : Measure E} [SigmaFinite ╬¢]
    (N : PoissonRandomMeasure P ╬¢)
    {t : ÔäØ} {B : Set (ÔäØ ├ù E)}
    (hB_subset : B Ôèå Set.Iic t ├ù╦ó Set.univ) (hB_meas : MeasurableSet B) :
    Measurable[(naturalFiltration N).seq t] (fun ¤ë => N.N ¤ë B) := by
  refine Measurable.of_comap_le (mÔéü := (naturalFiltration N).seq t) ?_
  change MeasurableSpace.comap (fun ¤ë => N.N ¤ë B) inferInstance Ôëñ (naturalFiltration N).seq t
  exact le_iSup_of_le B (le_iSup_of_le Ôş¿hB_subset, hB_measÔş® le_rfl)

/-- **Filtration ¤â-algebra equals the supremum used in `joint_past_future_independent`.**
This is `rfl`-level: the construction picks the same iSup as the structural
hypothesis on `PoissonRandomMeasure`. -/
lemma naturalFiltration_seq_eq
    {P : Measure ╬®} [IsProbabilityMeasure P]
    {╬¢ : Measure E} [SigmaFinite ╬¢]
    (N : PoissonRandomMeasure P ╬¢) (t : ÔäØ) :
    (naturalFiltration N).seq t =
      Ô¿å B Ôêê { C : Set (ÔäØ ├ù E) | C Ôèå Set.Iic t ├ù╦ó Set.univ Ôêğ MeasurableSet C },
        MeasurableSpace.comap (fun ¤ë => N.N ¤ë B) inferInstance := rfl

end LevyStochCalc.Poisson
